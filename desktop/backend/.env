# 智能车后端配置（仅在开发目录中有效，exe 移动到其他位置时使用内置默认值）

# 日志与调试
RUST_LOG=info
RUST_BACKTRACE=1

# 认证（生产环境必须设置 API_TOKEN；设置 DISABLE_AUTH=true 可禁用，仅用于测试）
# API_TOKEN=your-secure-token-here
# DISABLE_AUTH=false

# TLS/HTTPS（可选；同时设置 TLS_CERT 和 TLS_KEY 时启用 HTTPS/WSS）
# TLS_CERT=path/to/cert.pem
# TLS_KEY=path/to/key.pem
